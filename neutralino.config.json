{
  "applicationId": "js.neutralino.archidesk",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/index.html",
  "enableServer": true,
  "enableNativeAPI": true,
  "nativeAllowList": [
    "app.*",
    "os.*",
    "filesystem.*"
  ],
  "modes": {
    "window": {
      "title": "ArchiDesk",
      "width": 800,
      "height": 600,
      "enableInspector": true
    }
  },
  "cli": {
    "binaryName": "archidesk",
    "resourcesPath": "/dist/",
    "clientLibrary": "public/neutralino.js",
    "binaryVersion": "6.7.0",
    "clientVersion": "6.7.0"
  }
}